#!/usr/bin/env python3
"""Collect OptiTrack pose data for one or more rigid bodies (with per-body deflection
from each body's own initial origin pose)."""

from __future__ import annotations

import argparse
import csv
import math
import signal
import socket
import sys
import threading
import time
import traceback
from dataclasses import dataclass
from pathlib import Path

from natnet import NatNetClient, Version
from natnet.packet_buffer import PacketBuffer

# Folder where output CSVs are saved by default (next to this script).
OUTPUT_DIR = Path(__file__).resolve().parent / "data"

RIGID_IDS_DEFAULT = [33, 38]
RATE_HZ = 10.0
ORIGIN_DELAY_S = 5.0
MAX_OPTI_AGE_MS = 100.0

STOP = False


def patch_natnet_string_decoder() -> None:
    original = PacketBuffer.read_string
    if getattr(original, "_bota_optitrack_patched", False):
        return

    def read_string_lossy(self, max_length=None, static_length=False):
        if max_length is None:
            data_slice = self._PacketBuffer__data[self.pointer :]
        else:
            data_slice = self._PacketBuffer__data[self.pointer : self.pointer + max_length]
        str_enc, _separator, _remainder = bytes(data_slice).partition(b"\0")
        str_dec = str_enc.decode("utf-8", errors="replace")
        if static_length:
            assert max_length is not None
            self.pointer += max_length
        else:
            self.pointer += len(str_enc) + 1
        return str_dec

    read_string_lossy._bota_optitrack_patched = True
    PacketBuffer.read_string = read_string_lossy


patch_natnet_string_decoder()


def on_signal(_signum, _frame):
    global STOP
    STOP = True


def local_ip_for_server(server_ip: str) -> str:
    sock = socket.socket(socket.AF_INET, socket.SOCK_DGRAM)
    try:
        sock.connect((server_ip, 1510))
        return sock.getsockname()[0]
    finally:
        sock.close()


@dataclass
class OptiSample:
    local_ns: int
    frame: int | None
    motive_timestamp: float | None
    rigid_id: int
    seen: bool | None
    px: float | None
    py: float | None
    pz: float | None
    qx: float | None
    qy: float | None
    qz: float | None
    qw: float | None


class OptiTrackReceiver:
    """Tracks the latest pose for each rigid body ID in `rigid_ids`."""

    def __init__(self, server_ip: str, client_ip: str, rigid_ids: list[int], data_port: int, command_port: int, use_multicast: bool):
        self.rigid_ids = list(rigid_ids)
        self.lock = threading.Lock()
        self.samples: dict[int, OptiSample] = {}
        self.error: Exception | None = None
        self.client = NatNetClient(
            server_ip_address=server_ip,
            local_ip_address=client_ip,
            command_port=command_port,
            data_port=data_port,
            use_multicast=use_multicast,
        )
        self.client._NatNetClient__current_protocol_version = Version(4, 3)
        self.client.on_data_frame_received_event.handlers.append(self._on_frame)

    def _on_frame(self, frame):
        local_ns = time.monotonic_ns()
        bodies_by_id = {rb.id_num: rb for rb in (frame.rigid_bodies or ())}
        new_samples: dict[int, OptiSample] = {}
        for rigid_id in self.rigid_ids:
            body = bodies_by_id.get(rigid_id)
            if body is None:
                sample = OptiSample(local_ns, frame.prefix.frame_number, frame.suffix.timestamp, rigid_id, None, None, None, None, None, None, None, None)
            else:
                sample = OptiSample(
                    local_ns=local_ns,
                    frame=frame.prefix.frame_number,
                    motive_timestamp=frame.suffix.timestamp,
                    rigid_id=body.id_num,
                    seen=body.tracking_valid,
                    px=body.pos[0], py=body.pos[1], pz=body.pos[2],
                    qx=body.rot[0], qy=body.rot[1], qz=body.rot[2], qw=body.rot[3],
                )
            new_samples[rigid_id] = sample
        with self.lock:
            self.samples.update(new_samples)

    def start(self):
        self.client.connect(timeout=5.0)
        print(f"OptiTrack connected: protocol={self.client.protocol_version} server={self.client.server_info}")
        self.client.run_async()

    def latest(self, rigid_id: int) -> OptiSample | None:
        with self.lock:
            return self.samples.get(rigid_id)

    def stop(self):
        try:
            self.client.shutdown()
        except Exception as exc:
            self.error = exc


def quat_normalize(q: tuple[float, float, float, float]) -> tuple[float, float, float, float]:
    norm = math.sqrt(sum(v * v for v in q))
    if norm <= 0.0:
        raise ValueError("zero-length quaternion")
    return tuple(v / norm for v in q)


def quat_conjugate(q: tuple[float, float, float, float]) -> tuple[float, float, float, float]:
    qx, qy, qz, qw = q
    return (-qx, -qy, -qz, qw)


def quat_multiply(a: tuple[float, float, float, float], b: tuple[float, float, float, float]) -> tuple[float, float, float, float]:
    ax, ay, az, aw = a
    bx, by, bz, bw = b
    return (
        aw * bx + ax * bw + ay * bz - az * by,
        aw * by - ax * bz + ay * bw + az * bx,
        aw * bz + ax * by - ay * bx + az * bw,
        aw * bw - ax * bx - ay * by - az * bz,
    )


def quat_to_matrix(q: tuple[float, float, float, float]) -> tuple[tuple[float, float, float], tuple[float, float, float], tuple[float, float, float]]:
    qx, qy, qz, qw = quat_normalize(q)
    return (
        (1 - 2 * (qy * qy + qz * qz), 2 * (qx * qy - qz * qw), 2 * (qx * qz + qy * qw)),
        (2 * (qx * qy + qz * qw), 1 - 2 * (qx * qx + qz * qz), 2 * (qy * qz - qx * qw)),
        (2 * (qx * qz - qy * qw), 2 * (qy * qz + qx * qw), 1 - 2 * (qx * qx + qy * qy)),
    )


def mat_transpose_vec_mul(matrix, vec: tuple[float, float, float]) -> tuple[float, float, float]:
    return (
        matrix[0][0] * vec[0] + matrix[1][0] * vec[1] + matrix[2][0] * vec[2],
        matrix[0][1] * vec[0] + matrix[1][1] * vec[1] + matrix[2][1] * vec[2],
        matrix[0][2] * vec[0] + matrix[1][2] * vec[1] + matrix[2][2] * vec[2],
    )


def sample_pose(sample: OptiSample) -> tuple[tuple[float, float, float], tuple[float, float, float, float]]:
    if None in (sample.px, sample.py, sample.pz, sample.qx, sample.qy, sample.qz, sample.qw):
        raise ValueError("OptiTrack sample does not contain a full pose")
    return (sample.px, sample.py, sample.pz), quat_normalize((sample.qx, sample.qy, sample.qz, sample.qw))


def fresh_pose(opti: OptiTrackReceiver, rigid_id: int, max_age_ms: float) -> tuple[OptiSample, float] | None:
    now_ns = time.monotonic_ns()
    sample = opti.latest(rigid_id)
    if sample is None or sample.px is None:
        return None
    age_ms = (now_ns - sample.local_ns) / 1e6
    if age_ms > max_age_ms:
        return None
    return sample, age_ms


def capture_origins(opti: OptiTrackReceiver, rigid_ids: list[int], delay_s: float, max_age_ms: float) -> dict[int, OptiSample]:
    print(f"Waiting {delay_s:.1f}s before capturing origin poses for rigid bodies {rigid_ids}...")
    end = time.monotonic() + delay_s
    while not STOP and time.monotonic() < end:
        time.sleep(0.05)

    origins: dict[int, OptiSample] = {}
    timeout = time.monotonic() + 5.0
    remaining = set(rigid_ids)
    while not STOP and remaining and time.monotonic() < timeout:
        for rigid_id in list(remaining):
            fresh = fresh_pose(opti, rigid_id, max_age_ms)
            if fresh is not None:
                sample, age_ms = fresh
                print(
                    f"Origin frame collected [id={rigid_id}]: frame={sample.frame} age={age_ms:.1f}ms "
                    f"pos=({sample.px:.6f},{sample.py:.6f},{sample.pz:.6f}) "
                    f"quat=({sample.qx:.6f},{sample.qy:.6f},{sample.qz:.6f},{sample.qw:.6f})"
                )
                origins[rigid_id] = sample
                remaining.discard(rigid_id)
        if remaining:
            time.sleep(0.02)
    if remaining:
        raise RuntimeError(f"could not capture a fresh OptiTrack origin pose for rigid body ids {sorted(remaining)}")
    return origins


def parse_args() -> argparse.Namespace:
    parser = argparse.ArgumentParser(description="Collect OptiTrack pose data for one or more rigid bodies (with per-body deflection from each body's own origin).")
    parser.add_argument("--server-ip", default="172.24.68.77", help="Field Bay Motive/NatNet server IP")
    parser.add_argument("--client-ip", default=None, help="Local SRC network IP; auto-detected by default")
    parser.add_argument(
        "--rigid-id",
        dest="rigid_ids",
        type=int,
        nargs="+",
        default=list(RIGID_IDS_DEFAULT),
        help="OptiTrack rigid body ID(s), space separated for multiple, e.g. --rigid-id 34 35",
    )
    parser.add_argument("--data-port", type=int, default=1511, help="NatNet data port")
    parser.add_argument("--multicast", action="store_true", help="Use NatNet multicast data mode instead of unicast")
    parser.add_argument("--command-port", type=int, default=1510, help="NatNet command port")
    parser.add_argument("--origin-delay", type=float, default=ORIGIN_DELAY_S, help="Seconds to wait before capturing the origin pose")
    parser.add_argument("--max-opti-age-ms", type=float, default=MAX_OPTI_AGE_MS, help="Maximum OptiTrack sample age accepted as fresh")
    parser.add_argument("--duration", type=float, default=0.0, help="Seconds to log after origin capture; 0 means until Ctrl+C")
    parser.add_argument("--rate", type=float, default=RATE_HZ, help="Polling/logging loop rate in Hz")
    parser.add_argument("--print-rate", type=float, default=5.0, help="Terminal status rate in Hz")
    parser.add_argument("--label", default=None, help="Optional label included in the auto-generated CSV filename")
    parser.add_argument("--csv", default=None, help="Output CSV path")
    args = parser.parse_args()
    args.rigid_ids = list(dict.fromkeys(args.rigid_ids))  # de-dupe, keep order
    if args.client_ip is None:
        args.client_ip = local_ip_for_server(args.server_ip)
    if args.csv is None:
        timestamp = time.strftime("%Y%m%d_%H%M%S")
        ids_tag = "-".join(str(i) for i in args.rigid_ids)
        label_tag = f"_{args.label}" if args.label else ""
        csv_path = OUTPUT_DIR / f"optitrack_ids{ids_tag}{label_tag}_{timestamp}.csv"
    else:
        csv_path = Path(args.csv).expanduser()
    if not csv_path.is_absolute():
        csv_path = OUTPUT_DIR / csv_path
    csv_path.parent.mkdir(parents=True, exist_ok=True)
    args.csv = str(csv_path)
    return args


def build_fieldnames(rigid_ids: list[int]) -> list[str]:
    fieldnames = ["local_ns", "elapsed_s"]
    for rigid_id in rigid_ids:
        p = f"id{rigid_id}_"
        fieldnames += [
            f"{p}opti_local_ns", f"{p}opti_dt_ms", f"{p}opti_frame", f"{p}opti_timestamp", f"{p}opti_seen",
            f"{p}opti_px", f"{p}opti_py", f"{p}opti_pz", f"{p}opti_qx", f"{p}opti_qy", f"{p}opti_qz", f"{p}opti_qw",
            f"{p}origin_frame", f"{p}origin_px", f"{p}origin_py", f"{p}origin_pz",
            f"{p}origin_qx", f"{p}origin_qy", f"{p}origin_qz", f"{p}origin_qw",
            f"{p}deflection_x_m", f"{p}deflection_y_m", f"{p}deflection_z_m", f"{p}deflection_norm_m",
            f"{p}rel_qx", f"{p}rel_qy", f"{p}rel_qz", f"{p}rel_qw", f"{p}reorientation_angle_deg",
        ]
    return fieldnames


def main() -> int:
    signal.signal(signal.SIGINT, on_signal)
    signal.signal(signal.SIGTERM, on_signal)
    args = parse_args()

    print(f"OptiTrack server/client: {args.server_ip} / {args.client_ip}")
    print(f"OptiTrack data mode: {'multicast' if args.multicast else 'unicast'}")
    print(f"Target rigid body IDs: {args.rigid_ids}")
    print(f"CSV: {args.csv}")

    opti = None
    try:
        opti = OptiTrackReceiver(args.server_ip, args.client_ip, args.rigid_ids, args.data_port, args.command_port, args.multicast)
        opti.start()

        origins = capture_origins(opti, args.rigid_ids, args.origin_delay, args.max_opti_age_ms)
        origin_data = {}
        for rigid_id, origin in origins.items():
            origin_pos, origin_quat = sample_pose(origin)
            origin_data[rigid_id] = {
                "sample": origin,
                "pos": origin_pos,
                "quat": origin_quat,
                "rot": quat_to_matrix(origin_quat),
                "inv_quat": quat_conjugate(origin_quat),
            }

        fieldnames = build_fieldnames(args.rigid_ids)
        with open(args.csv, "w", newline="") as f:
            writer = csv.DictWriter(f, fieldnames=fieldnames)
            writer.writeheader()
            start_ns = time.monotonic_ns()
            last_print = 0.0
            period = 1.0 / max(args.rate, 1e-6)
            while not STOP:
                loop_start = time.perf_counter()
                now_ns = time.monotonic_ns()
                elapsed = (now_ns - start_ns) / 1e9
                if args.duration > 0 and elapsed >= args.duration:
                    break

                row = {"local_ns": now_ns, "elapsed_s": f"{elapsed:.9f}"}
                status_parts = []
                for rigid_id in args.rigid_ids:
                    p = f"id{rigid_id}_"
                    origin = origin_data[rigid_id]
                    sample = opti.latest(rigid_id)
                    dt_ms = None if sample is None else (now_ns - sample.local_ns) / 1e6

                    rel_pos = ("", "", "")
                    rel_norm = ""
                    rel_quat = ("", "", "", "")
                    rel_angle_deg = ""
                    if sample is not None and sample.px is not None:
                        pos, quat = sample_pose(sample)
                        world_delta = (
                            pos[0] - origin["pos"][0],
                            pos[1] - origin["pos"][1],
                            pos[2] - origin["pos"][2],
                        )
                        rel_pos = mat_transpose_vec_mul(origin["rot"], world_delta)
                        rel_norm = math.sqrt(sum(v * v for v in rel_pos))
                        rel_quat = quat_normalize(quat_multiply(origin["inv_quat"], quat))
                        rel_angle_deg = math.degrees(2.0 * math.acos(max(-1.0, min(1.0, abs(rel_quat[3])))))

                    row.update({
                        f"{p}opti_local_ns": "" if sample is None else sample.local_ns,
                        f"{p}opti_dt_ms": "" if dt_ms is None else f"{dt_ms:.3f}",
                        f"{p}opti_frame": "" if sample is None else sample.frame,
                        f"{p}opti_timestamp": "" if sample is None else sample.motive_timestamp,
                        f"{p}opti_seen": "" if sample is None else sample.seen,
                        f"{p}opti_px": "" if sample is None else sample.px,
                        f"{p}opti_py": "" if sample is None else sample.py,
                        f"{p}opti_pz": "" if sample is None else sample.pz,
                        f"{p}opti_qx": "" if sample is None else sample.qx,
                        f"{p}opti_qy": "" if sample is None else sample.qy,
                        f"{p}opti_qz": "" if sample is None else sample.qz,
                        f"{p}opti_qw": "" if sample is None else sample.qw,
                        f"{p}origin_frame": origin["sample"].frame,
                        f"{p}origin_px": origin["pos"][0], f"{p}origin_py": origin["pos"][1], f"{p}origin_pz": origin["pos"][2],
                        f"{p}origin_qx": origin["quat"][0], f"{p}origin_qy": origin["quat"][1],
                        f"{p}origin_qz": origin["quat"][2], f"{p}origin_qw": origin["quat"][3],
                        f"{p}deflection_x_m": rel_pos[0], f"{p}deflection_y_m": rel_pos[1], f"{p}deflection_z_m": rel_pos[2],
                        f"{p}deflection_norm_m": rel_norm,
                        f"{p}rel_qx": rel_quat[0], f"{p}rel_qy": rel_quat[1], f"{p}rel_qz": rel_quat[2], f"{p}rel_qw": rel_quat[3],
                        f"{p}reorientation_angle_deg": rel_angle_deg,
                    })

                    if sample is None:
                        status_parts.append(f"id{rigid_id}: waiting")
                    elif sample.px is None:
                        status_parts.append(f"id{rigid_id}: not in frame")
                    else:
                        stale_text = " STALE" if dt_ms is not None and dt_ms > args.max_opti_age_ms else ""
                        status_parts.append(
                            f"id{rigid_id}: dt={dt_ms:.1f}ms{stale_text} "
                            f"def=({rel_pos[0]:.3f},{rel_pos[1]:.3f},{rel_pos[2]:.3f})m "
                            f"angle={rel_angle_deg:.1f}deg"
                        )

                writer.writerow(row)

                if elapsed - last_print >= 1.0 / max(args.print_rate, 0.001):
                    last_print = elapsed
                    print(f"t={elapsed:7.3f}s | " + " || ".join(status_parts), flush=True)

                sleep_s = period - (time.perf_counter() - loop_start)
                if sleep_s > 0:
                    time.sleep(sleep_s)
        print(f"Wrote CSV: {args.csv}")
        return 0
    except Exception as exc:
        print(f"FATAL: {exc!r}", file=sys.stderr)
        traceback.print_exc()
        return 1
    finally:
        if opti is not None:
            opti.stop()


if __name__ == "__main__":
    raise SystemExit(main())
